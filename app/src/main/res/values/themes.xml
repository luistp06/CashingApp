<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CashingApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/morado_principal</item>
        <item name="colorPrimaryVariant">@color/morado_oscuro</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/morado_claro</item>
        <item name="colorOnSecondary">@color/blanco</item>
        <item name="android:windowBackground">@color/fondo</item>
        <item name="android:statusBarColor">@color/fondo</item>
        <item name="android:navigationBarColor">@color/superficie</item>
        <item name="colorSurface">@color/superficie</item>
        <item name="colorOnSurface">@color/texto_principal</item>
        <item name="bottomNavigationStyle">@style/BottomNav</item>
    </style>

    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
    </style>

    <style name="ShapeAppearance.App.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>