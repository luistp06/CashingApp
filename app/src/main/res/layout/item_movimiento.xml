<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/superficie_variante"
    app:cardCornerRadius="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- ICONO CATEGORÍA -->
        <TextView
            android:id="@+id/tv_icono"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/superficie"
            android:gravity="center"
            android:textSize="18sp"
            android:text="🛒"/>

        <!-- NOMBRE Y CATEGORÍA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_nombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supermercado"
                android:textColor="@color/texto_principal"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_categoria_fecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alimentación · Hoy"
                android:textColor="@color/texto_secundario"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- IMPORTE -->
        <TextView
            android:id="@+id/tv_importe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-45,30 €"
            android:textColor="@color/gasto"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>